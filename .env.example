# ── Backend (FastAPI / Ollama / Chroma / SQLite) ──
OLLAMA_BASE_URL=http://ollama-generation:11434
AGENT_MODEL=qwen3:1.7b

OLLAMA_JUDGE_URL=http://ollama-judge:11434
JUDGE_MODEL=deepseek-r1:1.5b

OLLAMA_EMBED_URL=http://ollama-embed:11434
EMBEDDING_MODEL=nomic-embed-text

CHROMA_DB_PATH=data/chroma_db
CHROMA_COLLECTION=reviews
CHROMA_ITEMS_COLLECTION=items
CHROMA_USER_REVIEWS_COLLECTION=user_reviews

RETRIEVAL_TOP_K=10
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.8
LLM_MAX_TOKENS=512
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///data/jollof.db

# ── Frontend (Vite — local dev + Docker build arg) ──
VITE_API_BASE_URL=http://localhost:8000

# ── Judge / submission bundles (optional — for fast setup without make pipeline) ──
# Set these to the GitHub Release download URLs after running make package-submission
MODELS_BUNDLE_URL=https://github.com/Kenny266/jollof-intelligence/releases/download/v1.0.0/ollama_models.tar.gz
DEMO_DATA_BUNDLE_URL=https://github.com/Kenny266/jollof-intelligence/releases/download/v1.0.0/demo_data.tar.gz
